# SynapseMesh — Environment Variables
# Copy this file to .env and fill in values before running locally or deploying.
# All VITE_ variables are embedded at build time and visible in the browser bundle.
# Never put secrets or private keys here.

# ─── WalletConnect ─────────────────────────────────────────────────────────────
# Required for RainbowKit's wallet modal (WalletConnect pairing).
# Get a free Project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ─── 0G Chain RPC ──────────────────────────────────────────────────────────────
# Defaults to the public Galileo testnet RPC. Override for mainnet or a private node.
# VITE_ZG_RPC_URL=https://evmrpc-testnet.0g.ai
# VITE_ZG_EXPLORER=https://chainscan-galileo.0g.ai

# ─── Live TEE Attestation Stream ───────────────────────────────────────────────
# Required to activate the real-time AttestationPosted event stream in chainStream.ts.
# Set to your deployed TeeVerifier contract address on 0G Chain.
# Leave empty to keep the UI in "unconfigured" demo mode (safe for development).
VITE_TEE_VERIFIER_ADDRESS=

# Optional: override the event topic if your contract uses a different signature.
# Default: keccak256("AttestationPosted(bytes32,bytes32,address,uint256,uint256)")
# VITE_TEE_ATTEST_TOPIC=0x...

# ─── Smart Contracts (set after deployment of 13 contracts) ─────────────────────
# These will be used by src/lib/contracts.ts once real addresses are known.
# VITE_CONTRACT_MESH_TOKEN=0x
# VITE_CONTRACT_MESH_ESCROW=0x
# VITE_CONTRACT_MESH_REGISTRY=0x
# VITE_CONTRACT_TASK_DAG=0x
# VITE_CONTRACT_MESH_STAKING=0x
# VITE_CONTRACT_TEE_VERIFIER=0x
# VITE_CONTRACT_MESH_GOVERNOR=0x
# VITE_CONTRACT_MESH_TREASURY=0x
# VITE_CONTRACT_MESH_FACTORY=0x
# VITE_CONTRACT_MESH_ORACLE=0x
# VITE_CONTRACT_MESH_INFT=0x
# VITE_CONTRACT_MESH_BRIDGE=0x
# VITE_CONTRACT_MESH_INCENTIVES=0x
