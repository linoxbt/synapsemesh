# SynapseMesh — Environment Variables
# Copy this file to .env and fill in values before running locally or deploying.
# All VITE_ variables are embedded at build time and visible in the browser bundle.
# Never put secrets or private keys here.

# ─── WalletConnect ─────────────────────────────────────────────────────────────
# Required for RainbowKit's wallet modal (WalletConnect pairing).
# Get a free Project ID at https://cloud.reown.com (formerly WalletConnect Cloud).
# REQUIRED — without a valid id the RainbowKit modal hangs on the WC handshake.
VITE_WALLETCONNECT_PROJECT_ID=f0d6f8162be1beccf221b4e2f8bd7026

# Bound the eth_getLogs scan window so a 33M-block chain doesn't freeze the UI.
# Set VITE_INDEX_FROM_BLOCK to your contracts' deploy block for full coverage,
# otherwise the UI scans the most recent VITE_INDEX_LOOKBACK_BLOCKS only.
VITE_INDEX_FROM_BLOCK=
VITE_INDEX_LOOKBACK_BLOCKS=200000
VITE_INDEX_CHUNK_BLOCKS=5000

# ─── 0G Chain RPC ──────────────────────────────────────────────────────────────
VITE_ZG_RPC_URL=https://evmrpc.0g.ai
VITE_ZG_EXPLORER=https://chainscan.0g.ai

# ─── Live TEE Attestation Stream ───────────────────────────────────────────────
# Required to activate the real-time AttestationPosted event stream in chainStream.ts.
# Set to your deployed TeeVerifier contract address on 0G Chain.
# Leave empty to keep the UI in "unconfigured" demo mode (safe for development).
VITE_TEE_VERIFIER_ADDRESS=0x4870CbC4D07d6Ac2EE5aA865588e5985FE77a4E9

# Optional: override the event topic if your contract uses a different signature.
# Default: keccak256("AttestationPosted(bytes32,bytes32,address,uint256,uint256)")
VITE_TEE_ATTEST_TOPIC=0xeb26a43a6c659dd466d7b33eb02355968ec2f414bf1419f72bcd5674773329c8

# ─── Smart Contracts (set after deployment of 13 contracts) ─────────────────────
# These will be used by src/lib/contracts.ts once real addresses are known.
VITE_CONTRACT_MESH_ESCROW=0x7B9421fF6588472b9f16D18c850017c942E3Df2e
VITE_CONTRACT_AGENT_REGISTRY=0x8CDe1A5e466712b133099dCBc3bBFF835eAfBe4d
VITE_CONTRACT_TASK_DAG_REGISTRY=0x78C08B5d9d72dd3B404eb43EdDEE0f9366d0E812
VITE_CONTRACT_BID_ENGINE=0x372Fc8c3149Da1Bf2a8eF2415867449Cd10f6209
VITE_CONTRACT_TEE_VERIFIER_BRIDGE=0x4d0DC0C2F32edfD234B8c179e77721bEBF1611cF
VITE_CONTRACT_REVENUE_ROUTER=0xa1313d218EbA5E0970A86C7140233976892631a5

VITE_CONTRACT_FITNESS_ORACLE=0x8313B473b8C9CaDcb56D4b5843A9BF61f7Beedd5
